{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Notiq",
  "version": "0.4.1",
  "identifier": "com.trexolab.notiq",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Notiq",
        "width": 800,
        "height": 600,
        "visible": false,
        "decorations": false,
        "shadow": true,
        "backgroundColor": "#0f172a"
      }
    ],
    "security": {
      "dangerousDisableAssetCspModification": ["style-src"],
      "csp": "default-src 'self'; script-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost blob: data: https: http:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; worker-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DOCUMENT/**",
          "$DESKTOP/**",
          "$DOWNLOAD/**",
          "$HOME/**",
          "$APPDATA/notiq/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Productivity",
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown",
        "name": "Markdown Note",
        "description": "Markdown Note — open with Notiq",
        "role": "Editor"
      },
      {
        "ext": ["txt"],
        "mimeType": "text/plain",
        "name": "Text Note",
        "description": "Text Note — open with Notiq",
        "role": "Editor"
      },
      {
        "ext": ["notiq"],
        "mimeType": "application/x-notiq",
        "name": "Notiq Note",
        "description": "Notiq Note",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/association.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerHooks": "nsis/installer-hooks.nsi"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"],
        "section": "utils",
        "priority": "optional",
        "desktopTemplate": "linux/notiq.desktop",
        "files": {
          "/usr/share/mime/packages/notiq-mime.xml": "mime/notiq-mime.xml",
          "/usr/share/icons/hicolor/128x128/mimetypes/application-x-notiq.png": "icons/association.png"
        }
      },
      "appimage": {
        "files": {
          "usr/share/mime/packages/notiq-mime.xml": "mime/notiq-mime.xml"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJEQTU3QTAzRjY5MzU2QUEKUldTcVZwUDJBM3FsdlVmVDY5dUxxUWZKUVB3eDIvYWNSZnhWUk9JNmhuVTM0NVErY3BhQ3phNlMK",
      "endpoints": [
        "https://github.com/trexolab-solution/notiq/releases/latest/download/latest.json"
      ]
    }
  }
}
